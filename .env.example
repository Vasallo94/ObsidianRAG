# ============================================================
# ObsidianRAG - Configuration
# ============================================================
# Copy this file as .env and adjust the values.
#
# All backend settings use the OBSIDIANRAG_ prefix.
# Example: OBSIDIANRAG_LLM_MODEL, OBSIDIANRAG_OLLAMA_BASE_URL

# ============ REQUIRED ============
# Full path to your Obsidian vault
OBSIDIANRAG_OBSIDIAN_PATH=/path/to/your/obsidian/vault

# ============ LLM MODEL ============
# Any model installed in Ollama (ollama pull <model>)
# Examples: gemma3, qwen2.5, llama3.2, mistral, phi3, etc.
OBSIDIANRAG_LLM_MODEL=gemma3

# ============ ADVANCED CONFIGURATION (optional) ============
# You normally don't need to change anything below

# Ollama URL (only if not on localhost)
# OBSIDIANRAG_OLLAMA_BASE_URL=http://localhost:11434

# Embeddings (huggingface works without additional configuration)
# OBSIDIANRAG_EMBEDDING_PROVIDER=huggingface
# OBSIDIANRAG_EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-mpnet-base-v2

# Reranker
# OBSIDIANRAG_USE_RERANKER=true
# OBSIDIANRAG_RERANKER_TOP_N=6

# Chunking
# OBSIDIANRAG_CHUNK_SIZE=1500
# OBSIDIANRAG_CHUNK_OVERLAP=300

# Retrieval
# OBSIDIANRAG_RETRIEVAL_K=12

# ============ DOCKER (only for docker compose) ============
# Host path to your Obsidian vault (mounted into the container)
OBSIDIAN_VAULT_PATH=/path/to/your/obsidian/vault
# LLM model used by the container (no OBSIDIANRAG_ prefix here)
LLM_MODEL=gemma3
